# NanthAI Edge — Web Frontend Environment Variables
# ==================================================
# Copy this file to .env.local and fill in your values.
# These are exposed to the browser (prefixed with VITE_).

# [REQUIRED] Your Convex deployment URL
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# [REQUIRED] Your Clerk publishable key (starts with pk_test_ or pk_live_)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your-key-here

# [OPTIONAL] Web push notifications — VAPID public key
# Must match the WEB_PUSH_VAPID_PUBLIC_KEY set in Convex env vars.
# Generate with: npx web-push generate-vapid-keys
VITE_WEB_PUSH_VAPID_PUBLIC_KEY=your-vapid-public-key

# [REQUIRED for Google integrations] Google OAuth client ID — for Google Calendar/Drive integration.
# Without this, "Connect Google Workspace" throws "Google OAuth is not configured for web."
#
# Where to find it:
#   Cloud Console → APIs & Services → Credentials → "OAuth 2.0 Client IDs" section.
#   Pick the client of type "Web application". Copy the Client ID (ends in
#   .apps.googleusercontent.com). This is DIFFERENT from VITE_GOOGLE_PICKER_API_KEY.
#
# Required redirect URIs on this OAuth client:
#   http://localhost:5173/oauth/google/callback
#   https://nanthai.tech/oauth/google/callback
#   (plus any Netlify preview origins you actively test)
#
# Required JavaScript origins on this OAuth client:
#   http://localhost:5173
#   https://nanthai.tech
#
# If no Web client exists yet: Create credentials → OAuth client ID → Web application.
VITE_GOOGLE_CLIENT_ID=123456789012-abc...xyz.apps.googleusercontent.com

# [OPTIONAL] Google Drive Picker — required for the Drive file picker on web.
# iOS/Android use a WebView Picker bridge and need the same values in their
# native build config.
# Both values must come from the SAME Google Cloud project that owns
# VITE_GOOGLE_CLIENT_ID above (and the OAuth client in convex/oauth/google_client_config.ts).
#
# 1. API key: Cloud Console → APIs & Services → Credentials → Create credentials → API key.
#    Restrict by HTTP referrer (http://localhost:5173/*, https://nanthai.tech/*, your Netlify
#    preview/prod origins) AND restrict by API → Google Picker API only.
#    Also enable "Google Picker API" in APIs & Services → Library.
# 2. App ID: Cloud Console → Home → Dashboard → "Project info" card → Project number (all digits).
#    NOT the project ID slug (e.g. "nanthai-edge"); this is the numeric ID like 123456789012.
VITE_GOOGLE_PICKER_API_KEY=your-restricted-google-picker-api-key
VITE_GOOGLE_PICKER_APP_ID=123456789012

# [OPTIONAL] Microsoft OAuth client ID — for Microsoft Calendar/OneDrive integration
VITE_MICROSOFT_CLIENT_ID=your-microsoft-app-id

# [OPTIONAL] Notion OAuth client ID — for Notion integration
VITE_NOTION_CLIENT_ID=your-notion-client-id

# [OPTIONAL] Slack OAuth client ID — for Slack integration
VITE_SLACK_CLIENT_ID=your-slack-client-id
